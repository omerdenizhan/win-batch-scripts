@echo off
:: ANSI renk kodlarının tanımlanması
set "ESC="
set "YESIL=%ESC%[92m"
set "SARI=%ESC%[93m"
set "RENK_SIFIRLA=%ESC%[0m"

:: Pencere boyutu tanımlanması
mode con cols=70 lines=25
cls

:: Kod sayfasını Türkçe karakterler için UTF-8 yapar
chcp 65001 >nul
title Script Çalışmaları
cls

:: Yönetici yetkisi kontrolü
net session >nul 2>&1
if %errorlevel% neq 0 (
echo. %YESIL%
echo  ====================================================================
echo                               U Y A R I
echo  ====================================================================
echo. %RENK_SIFIRLA%
echo  %SARI%Bu scripti çalıştırmak için dosyayı sağ tıklayıp "Yönetici olarak
echo  çalıştır" seçeneğini kullanmalısınız! %RENK_SIFIRLA%
echo. %YESIL%
echo  ====================================================================
echo. %RENK_SIFIRLA%

timeout /t 5 > nul
exit /b
)

:MENU
cls
echo. %YESIL%
echo  ====================================================================
echo                           SCRIPT ÇALIŞMALARI
echo  ====================================================================
echo. %RENK_SIFIRLA%
echo   %SARI%[1] Hibernate (Hazırda Beklet) Aktif
echo.
echo   [2] Hibernate (Hazırda Beklet) Pasif
echo.
echo   [3] OneDrive Kaldırma
echo.
echo   [4] Windows 11 HSL İçin Yerel Güvenlik İlkesi Kurulumu
echo.
echo   [5] Hosts Dosyasının İçeriğini Değiştir ve Başlangıca Ekle
echo.
echo   [6] Çıkış %RENK_SIFIRLA%
echo. %YESIL% 
echo  ====================================================================%RENK_SIFIRLA%
echo. 
echo. %SARI%

choice /c 123456 /m "  Seçim Yapınız "
echo %RENK_SIFIRLA%

if errorlevel 6 goto CIKIS
if errorlevel 5 goto HOSTS_DEGISTIR
if errorlevel 4 goto W11_HSL_YGI_KURULUMU
if errorlevel 3 goto ONEDRIVE_KALDIR
if errorlevel 2 goto ONAY_HIBERNATE_PASIF
if errorlevel 1 goto ONAY_HIBERNATE_AKTIF


::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::


:ONAY_HIBERNATE_AKTIF
cls
echo. %YESIL%
echo  ====================================================================
echo            Hibernate (Hazırda Beklet) Aktifleştirme Scripti %RENK_SIFIRLA%
echo. %SARI%
echo.
echo.
echo  Hazırda beklet modunu aktif etmek istiyor musunuz? (E/H): %RENK_SIFIRLA%

choice /c EH /n

if errorlevel 2 goto MENU
if errorlevel 1 goto HIBERNATE_AKTIF_UYGULA

:HIBERNATE_AKTIF_UYGULA
cls
echo. %YESIL%
echo  ====================================================================
echo            Hibernate (Hazırda Beklet) Aktifleştirme Scripti %RENK_SIFIRLA%
echo.
echo.
echo. %SARI%
echo  Hazırda beklet modu aktif ediliyor...
powercfg.exe /hibernate on
echo.
echo  İşlem tamamlandı. %RENK_SIFIRLA%

timeout /t 5 > nul
goto MENU


::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::


:ONAY_HIBERNATE_PASIF
cls
echo. %YESIL%
echo  ====================================================================
echo            Hibernate (Hazırda Beklet) Pasifleştirme Scripti %RENK_SIFIRLA%
echo.
echo.
echo. %SARI%
echo  Hazırda beklet modunu pasif etmek istiyor musunuz? (E/H): %RENK_SIFIRLA%

choice /c EH /n

if errorlevel 2 goto MENU
if errorlevel 1 goto HIBERNATE_PASIF_UYGULA

:HIBERNATE_PASIF_UYGULA
cls
echo. %YESIL%
echo  ====================================================================
echo            Hibernate (Hazırda Beklet) Pasifleştirme Scripti %RENK_SIFIRLA%
echo.
echo.
echo. %SARI%
echo  Hazırda beklet modu pasif ediliyor.
powercfg.exe /hibernate off
echo.
echo  İşlem tamamlandı. %RENK_SIFIRLA%

timeout /t 5 > nul
goto MENU


::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::


:ONEDRIVE_KALDIR
cls
echo. %YESIL%
echo  ====================================================================
echo                       OneDrive Kaldırma Scripti
echo.
echo. %RENK_SIFIRLA%
echo. %SARI%
echo  OneDrive uygulamasını tamamen istiyor musunuz? (E/H): %RENK_SIFIRLA%

choice /c EH /n

if errorlevel 2 goto MENU
if errorlevel 1 goto ONEDRIVE_KALDIR_UYGULA

:ONEDRIVE_KALDIR_UYGULA
cls
echo. %YESIL%
echo  ====================================================================
echo                       OneDrive Kaldırma Scripti
echo.
echo. %RENK_SIFIRLA%
echo. %SARI%
set x86="%SYSTEMROOT%\System32\OneDriveSetup.exe"
set x64="%SYSTEMROOT%\SysWOW64\OneDriveSetup.exe"
echo  OneDrive arka planda kapatılıyor.
taskkill /f /im OneDrive.exe > NUL 2>&1
ping 127.0.0.1 -n 5 > NUL 2>&1
echo.
echo  OneDrive kaldırılıyor.
if exist %x64% (%x64% /uninstall) else (%x86% /uninstall)
ping 127.0.0.1 -n 5 > NUL 2>&1
echo.
echo  OneDrive'dan arda kalanlar temizleniyor.
rd "%USERPROFILE%\OneDrive" /Q /S > NUL 2>&1
rd "C:\OneDriveTemp" /Q /S > NUL 2>&1
rd "%LOCALAPPDATA%\Microsoft\OneDrive" /Q /S > NUL 2>&1
rd "%PROGRAMDATA%\Microsoft OneDrive" /Q /S > NUL 2>&1 
echo.
echo  OneDrive Dosya Gezgini panelinden kaldırılıyor.
REG DELETE "HKEY_CLASSES_ROOT\CLSID\{018D5C66-4533-4307-9B53-224DE2ED1FE6}" /f > NUL 2>&1
REG DELETE "HKEY_CLASSES_ROOT\Wow6432Node\CLSID\{018D5C66-4533-4307-9B53-224DE2ED1FE6}" /f > NUL 2>&1
echo.
echo  OneDrive kaldırma işlemi tamamlandı. %RENK_SIFIRLA%

timeout /t 5 > nul
goto MENU


::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::


:W11_HSL_YGI_KURULUMU
cls
echo. %YESIL%
echo  ====================================================================
echo        Windows 11 HSL İçin Yerel Güvenlik İlkesi Kurulum Scripti
echo.
echo. %RENK_SIFIRLA%
echo. %SARI%
echo  Windows 11 HSL İçin Yerel Güvenlik İlkesi Kurulumu? (E/H): %RENK_SIFIRLA%

choice /c EH /n

if errorlevel 2 goto MENU
if errorlevel 1 goto W11_HSL_YGI_KURULUMU_UYGULA

:W11_HSL_YGI_KURULUMU_UYGULA
cls
echo. %YESIL%
echo  ====================================================================
echo        Windows 11 HSL İçin Yerel Güvenlik İlkesi Kurulum Scripti
echo.
echo. %RENK_SIFIRLA%
echo. %SARI%
cls
mode con cols=150 lines=50
echo  Kurulum başlatılıyor.
pushd "%~dp0" 
echo.
echo  İstemci Uzantıları Paketleri kurulumu yapılıyor.
dir /b %SystemRoot%\servicing\Packages\Microsoft-Windows-GroupPolicy-ClientExtensions-Package~3*.mum >List.txt 
echo.
echo  İstemci Araçları Paketleri kurulumu yapılıyor.
dir /b %SystemRoot%\servicing\Packages\Microsoft-Windows-GroupPolicy-ClientTools-Package~3*.mum >>List.txt 
for /f %%i in ('findstr /i . List.txt 2^>nul') do dism /online /norestart /add-package:"%SystemRoot%\servicing\Packages\%%i" 
echo.
echo  Paketlerin kurulumları tamamlandı. %RENK_SIFIRLA%

timeout /t 5 > nul
mode con cols=70 lines=25
goto MENU


